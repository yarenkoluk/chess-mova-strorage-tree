import tkinter as tk


class Node:
    def __init__(self, move=None, player=None, move_number=None, parent=None):
        self.move = move
        self.player = player
        self.move_number = move_number
        self.parent = parent
        self.children = []



class Tree:
    def __init__(self):
        self.root = Node()
        self.current = self.root

    def add_node(self, move, player, move_number):
        new_node = Node(move, player, move_number, self.current)
        self.current.children.append(new_node)
        self.current = new_node
    def go_back(self):
        if self.current.parent is not None:
            self.current = self.current.parent

    def dfs(self, node=None, depth=0):
        if node is None:
            node = self.root
        if not isinstance(node, Node):
            return ""
        result = ""
        if node.move is not None:
            result += "  " * depth
            result += f"{node.move} ({node.player}, {node.move_number})\n"
            if node == self.current:
               result += "  CURRENT"
               result += "\n"
        for child in node.children:
            result += self.dfs(child, depth + 1)

        return result
    

# ================= GUI =================
tree = Tree()

root = tk.Tk()
root.title("Yaren Chess Tree")
root.geometry("450x500")
root.configure(bg="#cce7f0")

tk.Label(
    root,
    text="Yaren Chess Tree",
    font=("Arial", 16),
    bg="#cce7f0"
).pack(pady=10)

tk.Label(root, text="Move", bg="#cce7f0").pack()
move_entry = tk.Entry(root)
move_entry.pack()

tk.Label(root, text="Player(White/ Black)", bg="#cce7f0").pack()
player_entry = tk.Entry(root)
player_entry.pack()

tk.Label(root, text="Move Number", bg="#cce7f0").pack()
number_entry = tk.Entry(root)
number_entry.pack()


def add_move():
    move = move_entry.get().strip()
    player = player_entry.get().strip()
    number = number_entry.get().strip()

    if not move or not player or not number:
        return

    if not number.isdigit():
        return

    tree.add_node(move, player, int(number))

    move_entry.delete(0, tk.END)
    player_entry.delete(0, tk.END)
    number_entry.delete(0, tk.END)

def go_back():
    tree.go_back()
    show_tree()

def show_tree():
    output.delete("1.0", tk.END)
    text = tree.dfs()   
    output.insert(tk.END, text if text else "(Tree boş)")

btn_frame = tk.Frame(root, bg="#cce7f0")
btn_frame.pack(pady=10)

tk.Button(root, text="Add Move", command=add_move).pack(pady=5)
tk.Button(root, text="Show Tree", command=show_tree).pack(pady=5)
tk.Button(root, text="Go Back", command=go_back).pack(pady=5)

output = tk.Text(root, height=15, width=50)
output.pack(pady=10)

root.mainloop()
